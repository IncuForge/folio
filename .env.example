# ══════════════════════════════════════════════════════════════════
# Folio — Environment Variables Reference
# ══════════════════════════════════════════════════════════════════
#
# DEPLOYMENT MODE is determined automatically:
#
#   ┌─ If DATABASE_URL is set ──→ Direct PostgreSQL (Docker/self-hosted)
#   └─ Otherwise ───────────────→ Supabase (cloud / Vercel)
#
# Copy this file to .env.local (local dev) or set these as
# Vercel / hosting-platform environment variables.
# ══════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────
# OPTION A: Supabase (Cloud / Vercel)
# Leave DATABASE_URL empty/unset to activate this mode.
# ─────────────────────────────────────────────────

# Public project URL (found in Supabase → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Service role key for server-side admin access (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Secret key used for signing session cookies cryptographically (generate a strong random string)
SESSION_SECRET=pick_a_strong_secret_key_or_use_openssl_rand_hex_32

# ─────────────────────────────────────────────────
# OPTION B: Direct PostgreSQL (Docker / Self-Hosted)
# Set DATABASE_URL to activate this mode (overrides Supabase).
# ─────────────────────────────────────────────────

# Direct Postgres connection string
# DATABASE_URL=postgresql://folio:your_password@localhost:5432/folio

# ─────────────────────────────────────────────────
# S3-Compatible Storage (used in Docker/self-hosted mode)
# In Supabase mode, storage is handled by Supabase Storage instead.
# ─────────────────────────────────────────────────

# SeaweedFS (or any S3-compatible) endpoint
# STORAGE_ENDPOINT=http://localhost:8333
# STORAGE_ACCESS_KEY=folio_access
# STORAGE_SECRET_KEY=your_storage_secret
# STORAGE_BUCKET=dish-images
# STORAGE_PUBLIC_URL=http://localhost:8333
